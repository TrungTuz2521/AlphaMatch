<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1565C0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_rounded"
        android:padding="24dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tiêu đề giữ nguyên text gốc -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🏆 Chọn Cấp Độ"
            android:fontFamily="@font/baloo2"
            android:textSize="26sp"
            android:textColor="#1565C0"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Level 1 – xanh lá -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnLevel1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#E8F5E9"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🐣"
                    android:textSize="40sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cấp 1"
                        android:fontFamily="@font/baloo2"
                        android:textSize="18sp"
                        android:textColor="#1B5E20"/>
<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="Lưới 6×6 · Cho bé mới chơi!"-->
<!--                        android:textSize="12sp"-->
<!--                        android:textColor="#2E7D32"-->
<!--                        android:fontFamily="@font/baloo2"/>-->
                </LinearLayout>
                <!-- Mũi tên -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="#43A047"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Level 2 – vàng -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnLevel2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#FFF8E1"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🦊"
                    android:textSize="40sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cấp 2 "
                        android:fontFamily="@font/baloo2"
                        android:textSize="18sp"
                        android:textColor="#E65100"/>
<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="Lưới 8×8 · Thử thách hơn!"-->
<!--                        android:textSize="12sp"-->
<!--                        android:textColor="#BF360C"-->
<!--                        android:fontFamily="@font/baloo2"/>-->
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="#FFB300"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Level 3 – xanh dương -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnLevel3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#E3F2FD"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="20dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🧠"
                    android:textSize="40sp"/>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cấp 3"
                        android:fontFamily="@font/baloo2"
                        android:textSize="18sp"
                        android:textColor="#0D47A1"/>
<!--                    <TextView-->
<!--                        android:layout_width="wrap_content"-->
<!--                        android:layout_height="wrap_content"-->
<!--                        android:text="Lưới 10×10 · Dành cho cao thủ!"-->
<!--                        android:textSize="12sp"-->
<!--                        android:textColor="#1565C0"-->
<!--                        android:fontFamily="@font/baloo2"/>-->
                </LinearLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="28sp"
                    android:textColor="#1976D2"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Nút Quay lại – giữ nguyên id -->
        <Button
            android:id="@+id/btnLevelCancel"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:backgroundTint="#EF5350"
            android:text="← Quay lại"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:fontFamily="@font/baloo2"
            app:cornerRadius="999dp"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>