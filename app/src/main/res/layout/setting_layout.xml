<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1565C0">

    <!-- Card chứa toàn bộ nội dung -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_rounded"
        android:padding="24dp"
        android:layout_marginHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Tiêu đề -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ Cài Đặt"
            android:fontFamily="@font/baloo2"
            android:textSize="26sp"
            android:textColor="#1565C0"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E3F2FD" android:layout_marginBottom="16dp"/>

        <!-- Nhạc nền -->
        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎵  Nhạc nền"
            android:fontFamily="@font/baloo2"
            android:textSize="20sp"
            android:textColor="#1565C0"
            android:layout_marginBottom="8dp"/>

        <RadioGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <RadioButton
                android:id="@+id/rbtnMusicOn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="#1565C0"
                android:text="Bật"
                android:textSize="16sp"
                android:textColor="#1565C0"
                android:fontFamily="@font/baloo2"/>

            <RadioButton
                android:id="@+id/rbtnMusicOff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:buttonTint="#EF5350"
                android:text="Tắt"
                android:textSize="16sp"
                android:textColor="#EF5350"
                android:fontFamily="@font/baloo2"/>
        </RadioGroup>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E3F2FD" android:layout_marginBottom="16dp"/>

